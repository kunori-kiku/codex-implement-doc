# Copy to `.env` and fill these workflow notification values.
# `.env` is gitignored. MCP credentials stay in `config.toml`.

# Comma-separated Telegram user IDs allowed to approve/reject/redirect runs.
TELEGRAM_USER_IDS=FILL_ME_TELEGRAM_USER_ID

# Verified sender address for Resend.
SENDER_EMAIL_ADDRESS=Codex Orchestrator <alerts@your-verified-domain.com>

# Comma-separated email recipients for incident reports and long notifications.
RESEND_TO=you@example.com

# Optional comma-separated CC/BCC recipients.
RESEND_CC=
RESEND_BCC=

# Optional reply-to address. Email replies are notification-only by default.
REPLY_TO_EMAIL_ADDRESSES=you@example.com
